layout { 
  default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

  tab name="Global" focus=true {
    pane split_direction="vertical" {
      pane name="Editor" command="nvim" 
      pane name="Console" command="bash"
    } 
  }
  tab name="Backend" {
    pane split_direction="vertical" {
      pane name="Editor" cwd="backend" command="nvim" 
      pane name="Console" cwd="backend" command="bash" {

      }

    }  
  }
  tab name="Frontend" {
    pane split_direction="vertical" {
      pane name="Console" cwd="frontend" command="bash" {
      
      }
      pane name="Vite Server"  command="just" {
        args "run-frontend"
      }
    }
  }
}