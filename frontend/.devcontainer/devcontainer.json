{
  "name": "HSK grammar",
  "build": {
    "dockerfile": "ContainerFile"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "Vue.volar",
        "tailwindCSS.experimental.classRegex": [
          ["@plugin\\s+\"([^\"]*)\"", "\"([^\"]*)\""]
        ]
      },
      "extensions": [
        "Vue.volar",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "ms-vscode.vscode-typescript-next"
      ]
    }
  }
}