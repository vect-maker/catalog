# --- Database Configuration (Turso/libSQL) ---
DB_TOKEN=your_turso_token_here
DB_URL=libsql://your-database-url.turso.io

# --- Backend Configuration ---
PORT=8080
SECRET_KEY=your_secure_jwt_secret_key_here
RUST_LOG=debug

# --- Networking & CORS ---
# Local Development
API_URL=http://localhost:8080
CLIENT_URL=http://localhost:5173

# Production (Used during build/deploy)
PROD_API_URL=https://your-backend.onrender.com
PROD_CLIENT_URL=https://your-frontend.netlify.app

# --- Store Metadata ---
VITE_STORE_NAME="Your Store Name"
VITE_STORE_PHONE_NUMBER=55555555555

# --- Admin Credentials (Startup/Seeding) ---
ADMIN_USER=admin
ADMIN_PASSWORD=1234
ADMIN_ID=019d83c7-3fe1-791c-851e-15697f8c1b9d
